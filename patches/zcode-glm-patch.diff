+
+def build_zcode_headers() -> dict:
+    """Return ZCode client headers matching the real ZCode Desktop fingerprint.
+
+    Reverse-engineered from ZCode Desktop 3.1.8 (zcode.cjs, eao() / rao()).
+    Z.AI's Cloudflare edge checks for a consistent client fingerprint; missing
+    or stale headers trigger 1010 / rate-limit challenges.
+    """
+    return {
+        # — Identity —
+        "User-Agent": f"ZCode/{_ZCODE_APP_VERSION} ai-sdk/anthropic/3.0.81",
+        "X-ZCode-App-Version": _ZCODE_APP_VERSION,
+        "X-ZCode-Agent": "glm",
+        # — Link tracing (HTTP client layer, fresh per request) —
+        "x-zcode-trace-id": uuid.uuid4().hex,
+        "x-request-id": uuid.uuid4().hex,
+        "x-session-id": _ZCODE_SESSION_ID,
+        "x-query-id": uuid.uuid4().hex,
+        # — Auxiliary (referral / display attribution) —
+        "HTTP-Referer": "https://zcode.z.ai",
+        "X-Title": "Z Code",
+    }
+
 
